---
import { searchEntries } from '../data/content';
import { pathFor } from '../lib/paths';

const index = searchEntries.map((entry) => ({ ...entry, path: pathFor(entry.path) }));
---

<dialog class="search-palette" id="search-palette" aria-labelledby="search-title">
  <div class="search-palette__head">
    <div>
      <span class="status-dot status-dot--verified"></span>
      <p id="search-title">Command index</p>
    </div>
    <button type="button" data-close-search aria-label="關閉搜尋">ESC</button>
  </div>
  <label class="search-field">
    <span class="sr-only">搜尋章節、工具與模板</span>
    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6"></circle><path d="m16 16 4 4"></path></svg>
    <input type="search" autocomplete="off" placeholder="搜尋 stage、template、concept…" role="combobox" aria-autocomplete="list" aria-expanded="false" aria-controls="search-results" data-search-input />
  </label>
  <div class="search-results" id="search-results" role="listbox" aria-label="搜尋結果" data-search-results aria-live="polite"></div>
  <div class="search-palette__foot">
    <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
    <span><kbd>↵</kbd> open</span>
    <span>Local index · no tracking</span>
  </div>
</dialog>

<script is:inline type="application/json" id="search-index" set:html={JSON.stringify(index).replace(/</g, '\\u003c')}></script>
<script is:inline>
  const searchDialog = document.querySelector('#search-palette');
  const searchInput = searchDialog?.querySelector('[data-search-input]');
  const searchResults = searchDialog?.querySelector('[data-search-results]');
  const searchIndex = JSON.parse(document.querySelector('#search-index')?.textContent || '[]');
  let activeIndex = 0;

  const escapeHtml = (value) => value.replace(/[&<>'"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' })[char]);
  const renderResults = () => {
    const query = (searchInput?.value || '').trim().toLowerCase();
    const matches = searchIndex.filter((item) => `${item.title} ${item.type} ${item.keywords}`.toLowerCase().includes(query)).slice(0, 9);
    activeIndex = Math.min(activeIndex, Math.max(0, matches.length - 1));
    if (!searchResults) return;
    searchResults.innerHTML = matches.length
      ? matches.map((item, index) => `<a id="search-result-${index}" role="option" aria-selected="${index === activeIndex}" href="${item.path}" data-result ${index === activeIndex ? 'data-active' : ''}><span><small>${escapeHtml(item.type)}</small>${escapeHtml(item.title)}</span><i aria-hidden="true">↗</i></a>`).join('')
      : '<p class="search-empty">沒有找到結果。試試「closure」、「connector」或「brief」。</p>';
    searchInput?.setAttribute('aria-activedescendant', matches.length ? `search-result-${activeIndex}` : '');
  };

  const openSearch = () => {
    if (!searchDialog?.open) searchDialog?.showModal();
    searchInput?.setAttribute('aria-expanded', 'true');
    renderResults();
    requestAnimationFrame(() => searchInput?.focus());
  };
  const closeSearch = () => {
    searchDialog?.close();
    searchInput?.setAttribute('aria-expanded', 'false');
  };

  document.querySelectorAll('[data-open-search]').forEach((button) => button.addEventListener('click', openSearch));
  searchDialog?.querySelector('[data-close-search]')?.addEventListener('click', closeSearch);
  searchDialog?.addEventListener('click', (event) => {
    if (event.target === searchDialog) closeSearch();
  });
  searchInput?.addEventListener('input', () => {
    activeIndex = 0;
    renderResults();
  });
  searchDialog?.addEventListener('close', () => searchInput?.setAttribute('aria-expanded', 'false'));
  searchDialog?.addEventListener('cancel', () => searchInput?.setAttribute('aria-expanded', 'false'));
  searchInput?.addEventListener('keydown', (event) => {
    const items = [...(searchResults?.querySelectorAll('[data-result]') || [])];
    if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
      event.preventDefault();
      if (!items.length) return;
      activeIndex = (activeIndex + (event.key === 'ArrowDown' ? 1 : -1) + items.length) % items.length;
      items.forEach((item, index) => {
        item.toggleAttribute('data-active', index === activeIndex);
        item.setAttribute('aria-selected', String(index === activeIndex));
      });
      searchInput?.setAttribute('aria-activedescendant', `search-result-${activeIndex}`);
      items[activeIndex]?.scrollIntoView({ block: 'nearest' });
    }
    if (event.key === 'Enter' && items[activeIndex]) items[activeIndex].click();
  });
  document.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      searchDialog?.open ? closeSearch() : openSearch();
    }
    if (event.key === '/' && !/input|textarea|select/i.test(document.activeElement?.tagName || '')) {
      event.preventDefault();
      openSearch();
    }
  });
</script>
