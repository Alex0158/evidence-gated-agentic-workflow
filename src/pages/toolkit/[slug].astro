---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { templates } from '../../data/content';

export function getStaticPaths() {
  return templates.map((template) => ({ params: { slug: template.slug } }));
}

const template = templates.find((item) => item.slug === Astro.params.slug)!;
const raw = template.module.rawContent();
const sourceUrl = `https://github.com/Alex0158/evidence-gated-agentic-workflow/blob/main/${template.sourcePath}`;
---

<SiteLayout title={template.title} description={template.purpose}>
  <PageHero
    eyebrow={`Toolkit / ${template.mode}`}
    title={template.title}
    accent="RAW MARKDOWN"
    description={template.purpose}
    meta={[{ label: 'Profile', value: template.mode }, { label: 'Format', value: '.md' }, { label: 'Source', value: 'Canonical' }, { label: 'Upload', value: 'Never' }]}
  />
  <section class="section control-zone">
    <div class="container template-detail" data-template-detail>
      <div class="template-detail__intro">
        <p class="eyebrow">Use the source</p>
        <h2 class="section-title">複製、裁剪、<br /><em>保留真正需要的 gate。</em></h2>
        <p class="lead">模板不是越完整越好。刪除不適用的欄位，但不要移除會改變 authority、recovery 或 claim boundary 的必要資訊。</p>
        <div class="button-row">
          <button class="button button--signal" type="button" data-copy-template>Copy Markdown <span>↗</span></button>
          <button class="button" type="button" data-download-template>Download .md <span>↓</span></button>
          <a class="button" href={sourceUrl}>GitHub source <span>↗</span></a>
        </div>
        <div class="notice notice--warning"><span class="status-dot status-dot--inferred"></span><p>Template 是 workflow aid，不構成 IAM enforcement、安全或 compliance 保證。</p></div>
      </div>
      <div class="template-preview"><pre><code data-template-preview>{raw}</code></pre></div>
      <textarea hidden aria-hidden="true" tabindex="-1" data-template-raw>{raw}</textarea>
    </div>
  </section>
</SiteLayout>

<script is:inline>
  document.querySelectorAll('[data-template-detail]').forEach((root) => {
    const raw = root.querySelector('[data-template-raw]')?.value || '';
    const copyText = async (text) => {
      if (!navigator.clipboard?.writeText) throw new Error('Clipboard unavailable');
      await navigator.clipboard.writeText(text);
    };
    root.querySelector('[data-copy-template]')?.addEventListener('click', async (event) => {
      const button = event.currentTarget;
      const original = button.innerHTML;
      try {
        await copyText(raw);
        button.textContent = 'Copied';
      } catch {
        button.textContent = 'Copy failed · download instead';
      }
      setTimeout(() => button.innerHTML = original, 1400);
    });
    root.querySelector('[data-download-template]')?.addEventListener('click', () => {
      const blob = new Blob([raw], { type: 'text/markdown;charset=utf-8' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `${location.pathname.split('/').filter(Boolean).pop() || 'template'}.md`;
      link.click();
      URL.revokeObjectURL(link.href);
    });
  });
</script>

<style>
  .template-detail { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(2rem, 5vw, 5rem); align-items: start; }
  .template-detail__intro { position: sticky; top: 7rem; }
  .template-detail__intro .lead { margin-bottom: 2rem; }
  .template-detail__intro .notice { margin-top: 2rem; }
  .template-detail__intro .notice p { margin: 0; }
  @media (max-width: 850px) { .template-detail { grid-template-columns: 1fr; } .template-detail__intro { position: static; } }
</style>
